{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.stayatmaredumilli.com" }],
      "destination": "https://stayatmaredumilli.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/hotels", "destination": "/hotels/index.html" },
    { "source": "/hotels/:slug", "destination": "/hotels/:slug/index.html" },
    { "source": "/policies/terms-of-service", "destination": "/policy.html" },
    { "source": "/policies/cancellation-policy", "destination": "/policy.html" },
    { "source": "/policies/check-in-policy", "destination": "/policy.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*).(mp4|jpg|jpeg|png|webp|gif|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*).(js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
